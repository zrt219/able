{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/home",
      "permanent": true
    },
    {
      "source": "/index",
      "destination": "/home",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/home",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/home",
      "destination": "/index.html"
    }
  ]
}
